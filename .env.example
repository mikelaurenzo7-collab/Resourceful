# Resourceful Configuration
# Copy this to .env and fill in your values

# Database (defaults to SQLite for dev; use PostgreSQL for production)
DATABASE_URL=sqlite+aiosqlite:///./resourceful.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/resourceful

# Auth
SECRET_KEY=generate-with-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Stripe Connect
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
PLATFORM_FEE_PERCENT=8.0

# App
DEBUG=true
