# ─── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── AI / Anthropic ──────────────────────────────────────────────────────────
AI_MODEL_PRIMARY=claude-sonnet-4-6       # most capable model
AI_MODEL_FAST=claude-haiku-4-5-20251001         # lightweight model
ANTHROPIC_API_KEY=sk-ant-...

# ─── Google Maps ──────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=your-server-side-google-maps-key
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-client-side-google-maps-key

# ─── ATTOM Property Data ─────────────────────────────────────────────────────
ATTOM_API_KEY=your-attom-api-key
ATTOM_API_BASE_URL=https://api.gateway.attomdata.com

# ─── Cook County Assessor ────────────────────────────────────────────────────
COOK_COUNTY_ASSESSOR_API_URL=https://datacatalog.cookcountyil.gov/resource

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Resend (Email) ──────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=reports@yourdomain.com

# ─── Admin ────────────────────────────────────────────────────────────────────
ADMIN_NOTIFICATION_EMAIL=admin@yourdomain.com

# ─── PDF Generation ──────────────────────────────────────────────────────────
PDF_SERVICE_URL=http://localhost:3000  # browserless or local puppeteer endpoint

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
