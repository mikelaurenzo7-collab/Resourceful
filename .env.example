# ============================================================
# Property Intelligence Platform — .env.example
# Copy to .env.local and fill in every value.
# NEVER commit .env.local to version control.
# Variables with NEXT_PUBLIC_ are visible in the browser.
# All others are server-side only — never use NEXT_PUBLIC_
# for secrets like service role keys or Stripe secret keys.
# ============================================================

# ---- AI --------------------------------------------------
# Get API key from console.anthropic.com under API Keys
ANTHROPIC_API_KEY=
# Optional FAST-provider override. Supported: anthropic, groq.
# Leave unset to keep Anthropic for all text generation.
AI_PROVIDER_FAST=anthropic

# Get API key from console.groq.com when using Groq's OpenAI-compatible API.
GROQ_API_KEY=

# Model names — update these to upgrade without code changes.
# PRIMARY: report narratives (quality matters — this writes the report)
# FAST: structured extraction, market research, comps/rentals fallback, county enrichment
# RESEARCH: tool-using county research agent; defaults to FAST when FAST stays on Anthropic
# Recommended Anthropic path: Sonnet + Haiku = ~$0.08-$0.15/report for text AI
# Recommended Groq path: set AI_PROVIDER_FAST=groq and AI_MODEL_FAST to your exact Groq model ID
AI_MODEL_PRIMARY=claude-sonnet-4-6
AI_MODEL_FAST=claude-haiku-4-5-20251001
AI_MODEL_RESEARCH=claude-haiku-4-5-20251001

# ---- Supabase --------------------------------------------
# Get from: Supabase project > Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key = full DB access. Server only. Never NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=
# Project ref: Settings > General (looks like: abcdefghijklmnop)
SUPABASE_PROJECT_REF=

# ---- Azure Maps ------------------------------------------
# Create at portal.azure.com > Maps Account > Authentication
# Server-only subscription key (never NEXT_PUBLIC_)
AZURE_MAPS_SUBSCRIPTION_KEY=
# Client ID for Azure Maps Web SDK (safe to expose)
NEXT_PUBLIC_AZURE_MAPS_CLIENT_ID=

# ---- Mapillary (street-level imagery, replaces Google Street View) -----
# Register at mapillary.com/developer and copy the Client Token
NEXT_PUBLIC_MAPILLARY_ACCESS_TOKEN=

# ---- ATTOM -----------------------------------------------
# Get from api.gateway.attomdata.com
# Required: property/detail, sale/snapshot, salestrend/detail endpoints
ATTOM_API_KEY=
# Optional: override ATTOM base URL (defaults to production)
# ATTOM_API_BASE_URL=https://api.gateway.attomdata.com/propertyapi/v1.0.0

# ---- Web Search (optional — improves public records + county enrichment) --
# Get from serper.dev ($50/mo for 50k searches)
SERPER_API_KEY=

# ---- LightBox RE (property data fallback when ATTOM returns zeros) -----------
# Get from lightboxre.com — key + secret for OAuth2 client credentials flow
LIGHTBOX_API_KEY=
LIGHTBOX_API_SECRET=

# ---- RentCast (rental comparable data for income approach) ------------------
# Get from rentcast.io — used in Stage 3 when ATTOM rental comps are empty
RENTCAST_API_KEY=

# ---- Regrid (parcel boundaries, zoning detail, legal descriptions) ----------
# Get from regrid.com — nationwide parcel data API
# Provides: parcel geometry (GeoJSON), lot dimensions, zoning descriptions,
# legal descriptions, APN, owner info. No other source has this data.
REGRID_API_KEY=

# ---- Mail Filing (optional — automated certified mail via Lob.com) -------
# Get from lob.com
LOB_API_KEY=

# ---- Stripe ----------------------------------------------
# Get from dashboard.stripe.com
# Use test keys (pk_test_, sk_test_) for development.
# Switch to live keys only for production with real payments.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
# Create webhook in Stripe Dashboard pointing to /api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=

# ---- Resend Email ----------------------------------------
# Get from resend.com — verify your sending domain first
RESEND_API_KEY=
# Sender address — must be from a verified domain in Resend
RESEND_FROM_ADDRESS=reports@yourdomain.com
# This address receives admin notifications and pipeline error alerts
ADMIN_NOTIFICATION_EMAIL=your@email.com

# ---- App -------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ---- Founders (comma-separated emails for free access) ---
FOUNDER_EMAILS=

# ---- Cron Security (Vercel auto-sets this for cron jobs) --
# Set manually for local testing of /api/cron/* endpoints
CRON_SECRET=

# ---- Gemini AI (for Vision / OCR) ----------------------------
# Get from aistudio.google.com/app/apikey
# Used for: photo analysis (deferred maintenance) and tax bill OCR
GEMINI_API_KEY=
# Optional model overrides. Default: gemini-3.1-pro.
GEMINI_MODEL_VISION=
GEMINI_MODEL_DOCUMENT=

# ---- Logging ---------------------------------------------
# Pino log level: trace | debug | info | warn | error | fatal
# Defaults to 'debug' in development, 'info' in production.
LOG_LEVEL=

# ---- Sentry (optional — error tracking) ------------------
# Get from sentry.io project settings. Leave blank to disable.
NEXT_PUBLIC_SENTRY_DSN=
# Auth token for sourcemap uploads (optional, recommended for production)
SENTRY_AUTH_TOKEN=

# ---- Report Access Tokens --------------------------------
# Secret used to sign /report/[id]?token=... links sent to non-signed-in clients.
# Falls back to SUPABASE_SERVICE_ROLE_KEY when unset — set a dedicated value in production.
REPORT_ACCESS_TOKEN_SECRET=
