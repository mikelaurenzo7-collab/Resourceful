{
  "functions": {
    "src/app/api/webhooks/stripe/route.ts": {
      "maxDuration": 300
    },
    "src/app/api/reports/[id]/download/route.ts": {
      "maxDuration": 120
    },
    "src/app/api/reports/[id]/viewer/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/cron/reminders/route.ts": {
      "maxDuration": 120
    },
    "src/app/api/cron/cleanup/route.ts": {
      "maxDuration": 120
    },
    "src/app/api/cron/outcome-followup/route.ts": {
      "maxDuration": 120
    },
    "src/app/api/cron/calibration/route.ts": {
      "maxDuration": 120
    },
    "src/app/api/cron/notification-retry/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/cron/cart-recovery/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/admin/reports/[id]/rerun/route.ts": {
      "maxDuration": 300
    },
    "src/app/api/admin/reports/[id]/regenerate/route.ts": {
      "maxDuration": 120
    },
    "src/app/api/cron/stale-pipeline/route.ts": {
      "maxDuration": 120
    }
