{
  "functions": {
    "src/app/api/webhooks/stripe/route.ts": {
      "maxDuration": 300
    },
    "src/app/api/cron/reminders/route.ts": {
      "maxDuration": 120
    },
    "src/app/api/cron/cleanup/route.ts": {
      "maxDuration": 120
    }
  },
  "crons": [
    {
      "path": "/api/cron/reminders",
      "schedule": "0 9 1 * *"
    },
    {
      "path": "/api/cron/cleanup",
      "schedule": "0 3 * * *"
    }
  ]
}
