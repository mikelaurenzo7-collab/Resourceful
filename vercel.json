    {
      "path": "/api/cron/outcome-followup",
      "schedule": "0 10 * * 1"
    },
    {
      "path": "/api/cron/calibration",
      "schedule": "0 4 * * 0"
    },
    {
      "path": "/api/cron/notification-retry",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/cart-recovery",
      "schedule": "30 * * * *"
    },
    {
      "path": "/api/cron/stale-pipeline",
      "schedule": "15 * * * *"
    }
  ]
}
